{
  "name": "data-viewer",
  "displayName": "Data Viewer",
  "description": "View tabular Jupyter variables and data files.",
  "version": "0.0.1",
  "publisher": "ChristofKaufmann",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Data Science",
    "Visualization"
  ],
  "keywords": [
    "jupyterVariableViewers",
    "csv",
    "npy",
    "jupyter",
    "dataframe",
    "array",
    "parquet",
    "feather",
    "data viewer"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "dataViewer.table",
        "displayName": "Data Viewer",
        "selector": [
          {
            "filenamePattern": "*.{csv,tsv,jsonl,ndjson}"
          },
          {
            "filenamePattern": "*.{csv,tsv,jsonl,ndjson}.{gz,bz2,zip,xz,zst,tar}"
          },
          {
            "filenamePattern": "*.{csv,tsv,jsonl,ndjson}.tar.{gz,xz,bz2}"
          },
          {
            "filenamePattern": "*.arrow"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "dataViewer.binary",
        "displayName": "Data Viewer",
        "selector": [
          {
            "filenamePattern": "*.{parquet,pq,feather,npy,npz}"
          },
          {
            "filenamePattern": "*.{parquet,pq}.{gz,bz2,zip,xz,zst,tar}"
          },
          {
            "filenamePattern": "*.{parquet,pq}.tar.{gz,xz,bz2}"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "dataViewer.open",
        "title": "Open in Data Viewer",
        "category": "Data Viewer"
      },
      {
        "command": "dataViewer.openJupyterVariable",
        "title": "Open Jupyter Variable in Data Viewer",
        "category": "Data Viewer"
      }
    ],
    "jupyterVariableViewers": [
      {
        "command": "dataViewer.openJupyterVariable",
        "title": "Open in Data Viewer",
        "dataTypes": [
          "DataFrame",
          "Series",
          "ndarray",
          "list",
          "dict"
        ]
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "dataViewer.open",
          "when": "resourceFilename =~ /\\.(csv|tsv|jsonl|ndjson|arrow)(\\.(tar\\.gz|tar\\.xz|tar\\.bz2|gz|bz2|zip|xz|zst|tar))?$/i",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "dataViewer.openJupyterVariable",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/jupyter-extension": "^1.1.1",
    "@vscode/python-extension": "^1.0.6",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0"
  }
}
